# LLM provider keys
OPENAI_API_KEY=
GEMINI_API_KEY=
# Optional; only used if an agent explicitly opts in
ANTHROPIC_API_KEY=

# Browser pool size for the harness (US-003); default 4
GBA_POOL_SIZE=4

# ---------------------------------------------------------------------------
# Hard-auth slice (US-028) — OPTIONAL real-site tasks against personal
# sandbox accounts. Every task in tasks/suite/hard-auth/ declares
# `requires_env`; if the listed vars are unset, the task is SKIPPED
# (terminal_state=SKIPPED_AUTH) and does NOT count as a failure or pass
# in the leaderboard. To opt in:
#
#   1. Create a SANDBOX account/repo/package for each service you want to
#      exercise. Do NOT point these at production assets.
#   2. Issue tokens that are scoped to the sandbox only.
#   3. Set the env vars below in your local .env. Never commit your .env.
#
# Token-scoping cheat sheet:
#   - GitHub PAT: settings → developer settings → personal access tokens →
#     fine-grained. Repository access: "only select repositories" → pick
#     the sandbox repo. Permissions: Issues=Read/Write, Contents=Read,
#     Metadata=Read. Token will look like "github_pat_…".
#   - Hugging Face: settings → access tokens → "Write" scope, scope to
#     the sandbox model repo only. Token will look like "hf_…".
#   - npm: granular access token (npm web UI → access tokens). Scope:
#     "Read and Publish" for the sandbox package ONLY. Set 2FA bypass off.
#     Token will look like "npm_…".
#   - Google Form: any public form URL with at least one required
#     short-answer field; no auth needed.
# ---------------------------------------------------------------------------

# GitHub: personal access token + "<owner>/<repo>" of the sandbox repo.
GITHUB_PAT=
GITHUB_SANDBOX_REPO=

# Hugging Face: token + "<owner>/<model-name>" of the sandbox model.
HF_TOKEN=
HF_TEST_REPO=

# npm: granular auth token + name of the sandbox package (NO publish in
# the task; the harness only drives the npm web UI).
NPM_AUTH_TOKEN=
NPM_SANDBOX_PACKAGE=

# Google Form: full URL of a public form configured with at least one
# required short-answer text field.
GOOGLE_FORM_PUBLIC_URL=
