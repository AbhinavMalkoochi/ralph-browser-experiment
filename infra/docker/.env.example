# Optional overrides for the hard-app slice (US-027).
# All values default to what docker-compose.yml already encodes; export these
# from your shell only if you need to override.

# Skip all self-hosted-app preflight checks. Tournament runner will SKIP
# the hard-app slice cleanly without attempting any HTTP probe.
# SKIP_SELF_HOSTED=1

# Seeded credentials (must match what infra/docker/seed/seed_gitea.sh and
# seed_vikunja.sh write). The harness loginAs helper reads these.
GBA_GITEA_USER=agent
GBA_GITEA_PASSWORD=agent-correct-horse-battery-staple
GBA_GITEA_ADMIN_USER=root
GBA_GITEA_ADMIN_PASSWORD=root-correct-horse-battery-staple

GBA_VIKUNJA_USER=agent
GBA_VIKUNJA_PASSWORD=agent-correct-horse-battery-staple
GBA_VIKUNJA_EMAIL=agent@example.invalid

GBA_BOOKSTACK_USER=agent@example.invalid
GBA_BOOKSTACK_PASSWORD=agent-correct-horse-battery-staple

# Host-mapped ports (mirror docker-compose.yml). Override only if you need
# to dodge a port collision.
GBA_GITEA_PORT=3001
GBA_EXCALIDRAW_PORT=3002
GBA_BOOKSTACK_PORT=3003
GBA_VIKUNJA_PORT=3004
